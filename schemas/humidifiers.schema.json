{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Humidifier",
  "type": "object",
  "required": ["brand", "model", "status", "source_url", "source_type", "source_date", "confidence_level"],
  "additionalProperties": true,
  "properties": {
    "brand":                        { "type": "string" },
    "series":                       { "type": ["string", "null"] },
    "model":                        { "type": "string" },
    "status":                       { "type": ["string", "null"], "enum": ["active", "discontinued", null] },
    "humidifier_type":              { "type": ["string", "null"] },
    "humidifier_role":              { "type": ["string", "null"] },
    "tank_capacity_l":              { "type": ["number", "null"], "minimum": 0 },
    "mist_output_ml_h_min":        { "type": ["number", "null"], "minimum": 0 },
    "mist_output_ml_h_max":        { "type": ["number", "null"], "minimum": 0 },
    "runtime_hours_max":            { "type": ["number", "null"], "minimum": 0 },
    "recommended_tent_min_cm":      { "type": ["number", "null"], "minimum": 0 },
    "recommended_tent_max_cm":      { "type": ["number", "null"], "minimum": 0 },
    "humidity_setpoint":            { "type": ["boolean", "null"] },
    "vpd_control":                  { "type": ["boolean", "null"] },
    "auto_mode":                    { "type": ["boolean", "null"] },
    "app_control":                  { "type": ["boolean", "string", "null"] },
    "wifi":                         { "type": ["boolean", "null"] },
    "bluetooth":                    { "type": ["boolean", "null"] },
    "controller_compatible":        { "type": ["boolean", "string", "null"] },
    "compatible_controller_brand":  { "type": ["string", "null"] },
    "compatible_controller_series": { "type": ["string", "null"] },
    "compatible_controller_models": { "type": ["string", "null"] },
    "hose_included":                { "type": ["boolean", "null"] },
    "external_probe_included":      { "type": ["boolean", "null"] },
    "power_watts_max":              { "type": ["number", "null"], "minimum": 0 },
    "noise_db_max":                 { "type": ["number", "null"], "minimum": 0 },
    "include_in_default_humidity_calculator": { "type": ["boolean", "null"] },
    "uvp_amount":                   { "type": ["number", "null"], "minimum": 0 },
    "uvp_currency":                 { "type": ["string", "null"] },
    "source_url":                   { "type": "string", "format": "uri" },
    "source_type":                  { "type": "string", "enum": ["manufacturer", "manufacturer_pdf", "retailer", "distributor", "review", "community"] },
    "source_date":                  { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "confidence_level":             { "type": "string", "enum": ["A+", "A", "B", "C", "D"] },
    "notes":                        { "type": ["string", "null"] }
  }
}
