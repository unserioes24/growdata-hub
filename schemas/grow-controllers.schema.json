{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Grow Controller",
  "description": "Schema for grow room climate and environmental controllers",
  "type": "object",
  "required": ["brand", "model", "status"],
  "additionalProperties": true,
  "definitions": {
    "tristate": {
      "anyOf": [
        { "type": "boolean" },
        { "type": "null" },
        { "type": "string", "enum": ["partial", "unknown", "optional", "needs_research", "conditional", "upcoming"] }
      ]
    },
    "confidence": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "enum": ["A", "B", "C", "D"] }
      ]
    }
  },
  "properties": {
    "brand": { "type": "string", "minLength": 1 },
    "series": { "type": ["string", "null"] },
    "model": { "type": "string", "minLength": 1 },
    "revision": { "type": ["string", "number", "null"] },
    "status": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "enum": ["active", "discontinued", "unknown", "upcoming", "needs_research"] }
      ]
    },
    "controller_type": { "type": ["string", "null"] },
    "controller_role": { "type": ["string", "null"] },
    "system_category": { "type": ["string", "null"] },
    "supported_devices": { "type": ["string", "null"] },
    "max_device_count": { "type": ["integer", "null"], "minimum": 1 },
    "max_ports": { "type": ["integer", "null"], "minimum": 1 },
    "port_types": { "type": ["string", "null"] },
    "plug_type": { "type": ["string", "null"] },
    "output_voltage_v": { "type": ["number", "null"], "minimum": 0 },
    "max_load_watts": { "type": ["number", "null"], "minimum": 0 },
    "max_load_amps": { "type": ["number", "null"], "minimum": 0 },
    "sensor_temperature": { "$ref": "#/definitions/tristate" },
    "sensor_humidity": { "$ref": "#/definitions/tristate" },
    "sensor_vpd": {
      "anyOf": [
        { "type": "boolean" },
        { "type": "null" },
        { "type": "string", "enum": ["calculated", "partial", "unknown", "optional", "needs_research", "conditional", "upcoming"] }
      ]
    },
    "sensor_co2": { "$ref": "#/definitions/tristate" },
    "sensor_light": { "$ref": "#/definitions/tristate" },
    "sensor_soil_moisture": { "$ref": "#/definitions/tristate" },
    "sensor_water_temp": { "$ref": "#/definitions/tristate" },
    "sensor_ph": { "$ref": "#/definitions/tristate" },
    "sensor_ec": { "$ref": "#/definitions/tristate" },
    "sensor_level": { "$ref": "#/definitions/tristate" },
    "sensor_pressure": { "$ref": "#/definitions/tristate" },
    "control_temperature": { "$ref": "#/definitions/tristate" },
    "control_humidity": { "$ref": "#/definitions/tristate" },
    "control_vpd": { "$ref": "#/definitions/tristate" },
    "control_fan_speed": { "$ref": "#/definitions/tristate" },
    "control_light_schedule": { "$ref": "#/definitions/tristate" },
    "control_light_dimming": { "$ref": "#/definitions/tristate" },
    "control_ir_uv": { "$ref": "#/definitions/tristate" },
    "control_co2": { "$ref": "#/definitions/tristate" },
    "control_irrigation": { "$ref": "#/definitions/tristate" },
    "control_ph": { "$ref": "#/definitions/tristate" },
    "control_ec": { "$ref": "#/definitions/tristate" },
    "control_heater": { "$ref": "#/definitions/tristate" },
    "control_dehumidifier": { "$ref": "#/definitions/tristate" },
    "control_humidifier": { "$ref": "#/definitions/tristate" },
    "control_pump": { "$ref": "#/definitions/tristate" },
    "app_control": { "$ref": "#/definitions/tristate" },
    "wifi": { "$ref": "#/definitions/tristate" },
    "bluetooth": { "$ref": "#/definitions/tristate" },
    "cloud_required": { "$ref": "#/definitions/tristate" },
    "local_control": { "$ref": "#/definitions/tristate" },
    "api_available": { "$ref": "#/definitions/tristate" },
    "mqtt_available": { "$ref": "#/definitions/tristate" },
    "automation_rules": { "$ref": "#/definitions/tristate" },
    "data_logging": { "$ref": "#/definitions/tristate" },
    "alerts": { "$ref": "#/definitions/tristate" },
    "display_included": { "$ref": "#/definitions/tristate" },
    "touchscreen": { "$ref": "#/definitions/tristate" },
    "firmware_updates": { "$ref": "#/definitions/tristate" },
    "ai_features": { "$ref": "#/definitions/tristate" },
    "ai_feature_type": { "type": ["string", "null"] },
    "ai_grow_assistant": { "$ref": "#/definitions/tristate" },
    "ai_climate_optimization": { "$ref": "#/definitions/tristate" },
    "ai_vpd_optimization": { "$ref": "#/definitions/tristate" },
    "ai_light_schedule_optimization": { "$ref": "#/definitions/tristate" },
    "ai_irrigation_optimization": { "$ref": "#/definitions/tristate" },
    "ai_nutrient_recommendations": { "$ref": "#/definitions/tristate" },
    "ai_anomaly_detection": { "$ref": "#/definitions/tristate" },
    "ai_alert_summarization": { "$ref": "#/definitions/tristate" },
    "ai_camera_analysis": { "$ref": "#/definitions/tristate" },
    "ai_plant_stage_detection": { "$ref": "#/definitions/tristate" },
    "ai_pest_detection": { "$ref": "#/definitions/tristate" },
    "ai_disease_detection": { "$ref": "#/definitions/tristate" },
    "ai_yield_prediction": { "$ref": "#/definitions/tristate" },
    "ai_training_recommendations": { "$ref": "#/definitions/tristate" },
    "ai_voice_assistant": { "$ref": "#/definitions/tristate" },
    "ai_requires_cloud": { "$ref": "#/definitions/tristate" },
    "ai_requires_subscription": { "$ref": "#/definitions/tristate" },
    "ai_data_export": { "$ref": "#/definitions/tristate" },
    "ai_notes": { "type": ["string", "null"] },
    "compatible_ec_fans": { "type": ["string", "boolean", "null"] },
    "compatible_lights": { "type": ["string", "boolean", "null"] },
    "compatible_sensors": { "type": ["string", "boolean", "null"] },
    "compatible_humidifiers": { "type": ["string", "boolean", "null"] },
    "compatible_irrigation": { "type": ["string", "boolean", "null"] },
    "compatible_co2_equipment": { "type": ["string", "boolean", "null"] },
    "compatible_brand_ecosystem": { "type": ["string", "null"] },
    "supported_manufacturer_series": { "type": ["string", "null"] },
    "power_supply_included": { "$ref": "#/definitions/tristate" },
    "mounting_type": { "type": ["string", "null"] },
    "length_mm": { "type": ["number", "null"], "minimum": 0 },
    "width_mm": { "type": ["number", "null"], "minimum": 0 },
    "height_mm": { "type": ["number", "null"], "minimum": 0 },
    "weight_kg": { "type": ["number", "null"], "minimum": 0 },
    "recommended_tent_min_cm": { "type": ["number", "null"], "minimum": 0 },
    "recommended_tent_max_cm": { "type": ["number", "null"], "minimum": 0 },
    "recommended_use_note": { "type": ["string", "null"] },
    "include_in_default_controller_calculator": { "$ref": "#/definitions/tristate" },
    "source_url": { "type": ["string", "null"] },
    "source_type": { "type": ["string", "null"] },
    "source_date": { "type": ["string", "null"] },
    "confidence_level": { "$ref": "#/definitions/confidence" },
    "uvp_amount": { "type": ["number", "null"], "minimum": 0 },
    "uvp_currency": { "type": ["string", "null"] },
    "uvp_source_url": { "type": ["string", "null"] },
    "uvp_source_type": { "type": ["string", "null"] },
    "uvp_source_date": { "type": ["string", "null"] },
    "uvp_confidence_level": { "type": ["string", "null"] },
    "uvp_notes": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
