{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Carbon Filter",
  "description": "Schema for inline carbon filter products",
  "type": "object",
  "required": ["brand", "model", "status"],
  "additionalProperties": false,
  "properties": {
    "brand": { "type": "string", "minLength": 1 },
    "series": { "type": ["string", "null"] },
    "model": { "type": "string", "minLength": 1 },
    "revision": { "type": ["string", "null"] },
    "status": { "type": "string", "enum": ["active", "discontinued"] },
    "filter_role": { "type": ["string", "null"] },
    "is_primary_filter_default": { "type": ["boolean", "null"] },
    "include_in_default_ventilation_calculator": { "type": ["boolean", "null"] },
    "filter_type": { "type": ["string", "null"] },
    "carbon_type": { "type": ["string", "null"] },
    "carbon_weight_kg": { "type": ["number", "null"], "minimum": 0 },
    "carbon_bed_thickness_mm": { "type": ["number", "null"], "minimum": 0 },
    "housing_material": { "type": ["string", "null"] },
    "pre_filter_included": { "type": ["boolean", "null"] },
    "pre_filter_replaceable": { "type": ["boolean", "null"] },
    "reversible": { "type": ["boolean", "null"] },
    "refillable": { "type": ["boolean", "null"] },
    "flange_diameter_mm": { "type": ["number", "null"], "minimum": 0 },
    "duct_size_label": { "type": ["string", "null"] },
    "length_mm": { "type": ["number", "null"], "minimum": 0 },
    "diameter_mm": { "type": ["number", "null"], "minimum": 0 },
    "weight_kg": { "type": ["number", "null"], "minimum": 0 },
    "max_airflow_m3_h": { "type": ["number", "null"], "minimum": 0 },
    "recommended_airflow_m3_h": { "type": ["number", "null"], "minimum": 0 },
    "min_airflow_m3_h": { "type": ["number", "null"], "minimum": 0 },
    "pressure_drop_pa": { "type": ["number", "null"], "minimum": 0 },
    "fan_match_note": { "type": ["string", "null"] },
    "odor_control_rating": { "type": ["string", "null"] },
    "lifetime_months_min": { "type": ["number", "null"], "minimum": 0 },
    "lifetime_months_max": { "type": ["number", "null"], "minimum": 0 },
    "humidity_limit_percent": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "temperature_limit_c": { "type": ["number", "null"] },
    "grow_area_min_cm": { "type": ["number", "null"], "minimum": 0 },
    "grow_area_max_cm": { "type": ["number", "null"], "minimum": 0 },
    "tent_size_recommendation": { "type": ["string", "null"] },
    "source_url": { "type": ["string", "null"] },
    "source_type": { "type": ["string", "null"] },
    "source_date": { "type": ["string", "null"] },
    "confidence_level": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "enum": ["A", "B", "C", "D"] }
      ]
    },
    "uvp_amount": { "type": ["number", "null"], "minimum": 0 },
    "uvp_currency": { "type": ["string", "null"] },
    "uvp_source_url": { "type": ["string", "null"] },
    "uvp_source_type": { "type": ["string", "null"] },
    "uvp_source_date": { "type": ["string", "null"] },
    "uvp_confidence_level": { "type": ["string", "null"] },
    "uvp_notes": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
